# API Keys (不要提交到 GitHub!)
GITHUB_TOKEN=your_github_token_here
NOTION_API_KEY=your_notion_integration_token
OPENROUTER_API_KEY=your_openrouter_key  # 或 use_llama_cpp=true 用本地模型
PEXELS_API_KEY=your_pexels_api_key
XIAOHONGSHU_CDP_KEY=your_cdp_key

# LLM Settings
USE_LLAMA_CPP=false
LLAMA_MODEL_PATH=~/.cache/llama/Qwen1.5-7B-Chat-GGUF/q4_k_m.gguf
LLM_PROVIDER=openrouter

# Browser Harness
BU_NAME=default
BU_CDP_WS=ws://127.0.0.1:9222

# Scrapers
SCRAPING_INTERVAL_MINUTES=30
PLATFORMS=weibo,zhihu,douyin

# Content Settings
AI_SCORE_THRESHOLD=7.5  # 选题评分阈值 (0-10)
DAILY_POST_LIMIT=3
