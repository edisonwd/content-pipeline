# API Keys (不要提交到 GitHub!)
GITHUB_TOKEN=your_github_token_here
NOTION_API_KEY=your_notion_integration_token
DASHSCOPE_API_KEY=sk-xxx  # 阿里云百炼: https://bailian.console.aliyun.com/#/api-key
PEXELS_API_KEY=your_pexels_api_key
XIAOHONGSHU_CDP_KEY=your_cdp_key

# LLM Settings
LLM_PROVIDER=dashscope
DASHSCOPE_MODEL=qwen-max  # qwen-max / qwen-plus / qwen-turbo

# Browser Harness
BU_NAME=default
BU_CDP_WS=ws://127.0.0.1:9222

# Scrapers
SCRAPING_INTERVAL_MINUTES=30
PLATFORMS=weibo,zhihu,douyin

# Content Settings
AI_SCORE_THRESHOLD=7.5  # 选题评分阈值 (0-10)
DAILY_POST_LIMIT=3
